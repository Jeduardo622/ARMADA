# App
NODE_ENV=development
PORT=4500
LOG_LEVEL=info

# Auth/session
JWT_SECRET=change-me
TOKEN_TTL_HOURS=12

# Data stores (local via Docker)
DATABASE_URL=postgres://postgres:postgres@localhost:15432/armada
REDIS_URL=redis://localhost:6379

# Config/flags (local Unleash or simple signed JSON service)
CONFIG_SERVICE_URL=http://localhost:4500
CONFIG_SIGNING_KEY=dev-config-signing-key
FLAG_SERVICE_URL=http://localhost:4242
FLAG_SERVICE_API_TOKEN=dev-flag-api-token

# Telemetry/APM (optional; set if using Sentry/Grafana/Amplitude/etc.)
TELEMETRY_ENDPOINT=
TELEMETRY_API_KEY=
SENTRY_DSN=

# Assets/Object storage (local MinIO)
# Console at http://localhost:9100 when running docker command with 9100:9090
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minio-access
STORAGE_SECRET_KEY=minio-secret
ASSET_BUCKET=armada-dev
ASSET_CDN_BASE=http://localhost:9000/armada-dev

# Payments (later; leave blank until wired)
IAP_APPLE_SHARED_SECRET=
IAP_GOOGLE_SERVICE_ACCOUNT_JSON=
