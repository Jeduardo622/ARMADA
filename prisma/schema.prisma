generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MissionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  FAILED
}

model Player {
  id          String           @id @default(uuid())
  externalId  String?          @unique
  displayName String?
  region      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  inventory   InventoryItem[]
  missions    MissionProgress[]
  telemetry   TelemetryEvent[]
  upgrades    PlayerShipUpgrade[]
  matchSeats  MatchParticipant[]
}

// Server-authoritative PvP match lifecycle (pvp_api routes). Status/side/
// result are TEXT with app-level constants (src/routes/pvp.ts) rather than
// Postgres enums to keep the migration additive and the rollback a plain
// table drop.
model Match {
  id           String   @id @default(uuid())
  code         String   @unique
  status       String   @default("WAITING_FOR_OPPONENT")
  scenarioCode String
  seed         Int
  modifiers    Json
  // Next turn to resolve; submit-orders binds {matchId, turnNumber} and
  // mismatches are rejected (409 turn_conflict).
  turnNumber   Int      @default(1)
  // Current SimState. Server-written only: no route ever persists
  // client-supplied state.
  state        Json
  // Append-only per-turn records [{turn, hash, summary, events}].
  turnEvents   Json     @default("[]")
  result       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  participants MatchParticipant[]

  @@index([status])
}

model MatchParticipant {
  id            String   @id @default(uuid())
  matchId       String
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId      String
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  side          String
  // Orders staged for turn pendingTurn; never returned to the opponent
  // before the turn resolves.
  pendingOrders Json?
  pendingTurn   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([matchId, side])
  @@unique([matchId, playerId])
  @@index([playerId])
}

model InventoryItem {
  id        String   @id @default(uuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  itemKey   String
  quantity  Int      @default(0)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, itemKey])
  @@index([playerId])
}

model PlayerShipUpgrade {
  id        String   @id @default(uuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  component String
  tier      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, component])
  @@index([playerId])
}

model Mission {
  id            String            @id @default(uuid())
  code          String            @unique
  name          String
  description   String?
  configVersion Int               @default(1)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  progress      MissionProgress[]
}

model MissionProgress {
  id          String        @id @default(uuid())
  playerId    String
  missionId   String
  status      MissionStatus @default(NOT_STARTED)
  bestScore   Int?
  lastResult  Json?
  updatedAt   DateTime      @updatedAt
  createdAt   DateTime      @default(now())
  player      Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  mission     Mission       @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([playerId, missionId])
  @@index([missionId])
}

model ConfigSnapshot {
  id        Int      @id @default(autoincrement())
  namespace String
  version   Int
  content   Json
  checksum  String
  createdAt DateTime @default(now())

  @@unique([namespace, version], map: "namespace_version")
  @@index([namespace])
}

model FeatureFlag {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  description  String?
  enabled      Boolean  @default(false)
  defaultState String?  // e.g., variant name or rollout description
  createdAt    DateTime @default(now())
}

model TelemetryEvent {
  id            BigInt   @id @default(autoincrement())
  playerId      String?
  missionCode   String?
  schemaVersion Int
  payload       Json
  receivedAt    DateTime @default(now())
  player        Player?  @relation(fields: [playerId], references: [id])
}

